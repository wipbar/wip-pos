{
  "name": "wip-pos",
  "private": true,
  "scripts": {
    "start": "DISABLE_SOCKJS=1 meteor run --settings settings.json --port 1338",
    "start-prod": "MONGO_URL=$(jq -r '.\"galaxy.meteor.com\".env.MONGO_URL' production-settings.json) MONGO_OPLOG_URL=$(jq -r '.\"galaxy.meteor.com\".env.MONGO_OPLOG_URL' production-settings.json) meteor run --settings production-settings.json",
    "dump-prod": "mongodump --uri=\"$(jq '.\"galaxy.meteor.com\".env.MONGO_URL' production-settings.json)\" --out=\"mongodump/$(date '+%Y-%m-%d-%H:%M:%S')\"",
    "restore-local-from-dump": "mongorestore -h 127.0.0.1 --port 1339 --drop --nsFrom=\"test.*\" --nsTo=\"meteor.*\"",
    "copy-prod": "npm run dump-prod && npm run restore-local-from-dump mongodump/$(ls -Art mongodump | tail -n 1)",
    "test": "meteor test --once --driver-package meteortesting:mocha",
    "test-app": "TEST_WATCH=1 meteor test --full-app --driver-package meteortesting:mocha",
    "visualize": "meteor --production --extra-packages bundle-visualizer",
    "deploy": "cd .deploy && time mup deploy"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@swc/helpers": "^0.5.23",
    "@types/meteor": "^2.9.11",
    "bcrypt": "^6.0.0",
    "convert": "^7.0.0",
    "date-fns": "^4.4.0",
    "fast-average-color": "^9.5.2",
    "history": "^5.3.0",
    "jquery": "^4.0.0",
    "lodash": "^4.18.1",
    "meteor-node-stubs": "^1.2.27",
    "polished": "^4.3.1",
    "react": "^19.2.7",
    "react-countdown": "^2.3.6",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-qr-code": "^2.2.0",
    "react-router": "^8.2.0",
    "react-select": "^5.10.2",
    "react-use-draggable-scroll-safe": "^0.5.4",
    "recharts": "^3.9.2",
    "tdigest": "^0.1.2",
    "use-long-press": "^3.3.0"
  },
  "meteor": {
    "mainModule": {
      "client": "client/main.tsx",
      "server": "server/main.ts"
    },
    "testModule": "tests/main.ts",
    "modern": true
  },
  "devDependencies": {
    "@meteorjs/rspack": "^2.0.1",
    "@rsdoctor/rspack-plugin": "^1.5.17",
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@rspack/plugin-react-refresh": "^1.6.2",
    "@types/fibers": "^3.1.4",
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "babel-eslint": "^10.1.0",
    "eslint": "^8.46.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-babel": "^5.3.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "react-refresh": "^0.18.0",
    "typescript": "^6.0.3"
  }
}
